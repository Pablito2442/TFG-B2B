# Configuración de Conexión a Neo4j (Docker)
# Copia este archivo a .env y ajusta los valores si es necesario
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=AdminUser1234
NEO4J_DATABASE=neo4j

# Autenticación JWT — cambia este valor en producción
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-string

# Deployment — full public URL (no trailing slash)
# Local:      leave empty (defaults kick in)
# VPS+domain: PUBLIC_URL=https://b2b-graph-intel.duckdns.org
PUBLIC_URL=
